{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "items.json",
  "description": "Item search data for the Dark and Darker wiki",
  "type": "object",
  "required": ["generated_at", "dungeons", "rarities", "items", "sources", "pools", "rates"],
  "properties": {
    "generated_at": {
      "type": "string",
      "description": "ISO 8601 timestamp of generation"
    },
    "dungeons": {
      "type": "array",
      "description": "Dungeon definitions with name and grade tiers"
    },
    "rarities": {
      "type": "array"
    },
    "items": {
      "type": "array",
      "description": "List of item names"
    },
    "sources": {
      "type": "array",
      "description": "Loot source entries"
    },
    "pools": {
      "type": "array",
      "description": "Loot pool definitions"
    },
    "rates": {
      "type": "array",
      "description": "Drop rate data"
    }
  }
}
