{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "quests.json",
  "description": "Quest data for the Dark and Darker wiki",
  "type": "object",
  "required": ["generated_at", "total_quests", "total_merchants", "merchants"],
  "properties": {
    "generated_at": {
      "type": "string",
      "description": "ISO 8601 timestamp of generation"
    },
    "source": { "type": "string" },
    "total_quests": { "type": "integer", "minimum": 1 },
    "total_merchants": { "type": "integer", "minimum": 1 },
    "merchants": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "chapters"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "portrait": { "type": "string" },
          "chapters": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["name", "order", "quests"],
              "properties": {
                "name": { "type": "string" },
                "order": { "type": "integer" },
                "quests": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["id", "title"],
                    "properties": {
                      "id": { "type": "string" },
                      "title": { "type": "string" },
                      "quest_number": { "type": "integer" },
                      "required_level": { "type": "integer" },
                      "greeting": { "type": "string" },
                      "completion_text": { "type": "string" },
                      "prerequisite": { "type": "object" },
                      "dungeons": {
                        "type": "array",
                        "items": { "type": "string" }
                      },
                      "objectives": {
                        "type": "array",
                        "items": { "type": "object" }
                      },
                      "rewards": {
                        "type": "array",
                        "items": { "type": "object" }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
