{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "classes.json",
  "description": "Class data for the Dark and Darker wiki",
  "type": "object",
  "required": ["version", "generated_at", "data"],
  "properties": {
    "version": {
      "type": "string",
      "description": "Version/date of generation"
    },
    "generated_at": {
      "type": "string",
      "description": "ISO 8601 timestamp of generation"
    },
    "data": {
      "type": "object",
      "required": ["classes"],
      "properties": {
        "classes": {
          "type": "array",
          "minItems": 10,
          "items": {
            "type": "object",
            "required": ["slug", "name", "role", "base_stats", "derived_stats", "perks", "skills"],
            "properties": {
              "slug": { "type": "string" },
              "name": { "type": "string" },
              "flavor_text": { "type": "string" },
              "role": { "type": "string", "enum": ["Melee", "Caster", "Hybrid"] },
              "base_stats": { "type": "object" },
              "derived_stats": { "type": "object" },
              "perks": { "type": "array" },
              "skills": { "type": "array" },
              "spells": { "type": "array" },
              "shapeshifts": { "type": "array" },
              "usable_item_count": { "type": "integer" }
            }
          }
        },
        "spell_merge_recipes": { "type": "array" }
      }
    }
  }
}
