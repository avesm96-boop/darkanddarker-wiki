{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "monsters.json",
  "description": "Monster data for the Dark and Darker wiki",
  "type": "object",
  "required": ["generated_at", "monsters"],
  "properties": {
    "generated_at": {
      "type": "string",
      "description": "ISO 8601 timestamp of generation"
    },
    "monsters": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["slug", "name", "class_type"],
        "properties": {
          "slug": { "type": "string" },
          "name": { "type": "string" },
          "class_type": {
            "type": "string",
            "enum": ["Normal", "Elite", "Boss", "SubBoss", "NPC"]
          },
          "creature_types": {
            "type": "array",
            "items": { "type": "string" }
          },
          "image": { "type": "string" },
          "dungeons": {
            "type": "array",
            "items": { "type": "string" }
          },
          "spawn_locations": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "dungeon": { "type": "string" },
                "module": { "type": "string" }
              }
            }
          },
          "grades": { "type": "object" }
        }
      }
    }
  }
}
